{% comment %}
  Renders cart notification

  Accepts:
  - color_scheme: {String} sets the color scheme of the notification (optional)
  - desktop_menu_type: {String} passes the desktop menu type which allows us to use the right css class (optional)

  Usage:
  {% render 'cart-notification' %}
{% endcomment %}

<cart-notification>
  <div class="cart-notification-wrapper{% if desktop_menu_type != 'drawer' %} page-width{% endif %}">
    <div
      id="cart-notification"
      class="cart-notification focus-inset{% if color_scheme %} color-{{ color_scheme }} gradient{% endif %}"
      aria-modal="true"
      aria-label="{{ 'general.cart.item_added' | t }}"
      role="dialog"
      tabindex="-1"
    >
      <div class="cart-notification__header">
        <h2 class="cart-notification__heading caption-large text-body">
          {{- 'icon-checkmark.svg' | inline_asset_content -}}
          {{ 'general.cart.item_added' | t }}
        </h2>
        <button
          type="button"
          class="cart-notification__close modal__close-button link link--text focus-inset"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>
      <div id="cart-notification-product" class="cart-notification-product"></div>

      <!-- Shirt Promotion Section for Cart Notification -->
      <div id="cart-notification-shirt-promotion" class="shirt-promotion" style="display: none; padding: 1rem; margin: 1rem 0; background: linear-gradient(135deg, #f8f9fa, #e9ecef); border-radius: 8px; border-left: 4px solid #28a745;">
        <div id="cart-notification-shirt-promotion-encourage" style="display: none;">
          <strong>Add one more shirt (any style) and save $15</strong>
        </div>
        <div id="cart-notification-shirt-promotion-congratulate" style="display: none;">
          <strong>You're saving $15 by ordering 2 or more</strong>
        </div>
      </div>

      <div class="cart-notification__links">
        <a
          href="{{ routes.cart_url }}"
          id="cart-notification-button"
          class="button button--secondary button--full-width"
        >
          {{- 'general.cart.view_empty_cart' | t -}}
        </a>
        <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form">
          <button class="button button--primary button--full-width" name="checkout">
            {{ 'sections.cart.checkout' | t }}
          </button>
        </form>
        <button type="button" class="link button-label">{{ 'general.continue_shopping' | t }}</button>
      </div>
    </div>
  </div>
</cart-notification>
{% style %}
  .cart-notification {
    display: none;
  }

  .cart-notification__quantity {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .cart-notification__quantity-label {
    font-size: 1.3rem;
  }

  .cart-notification__quantity-selector {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .cart-notification__quantity-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background-color: rgba(var(--color-foreground), 0.05);
    cursor: pointer;
    font-size: 1.7rem;
    line-height: 1;
    color: rgb(var(--color-foreground));
    transition: background-color var(--duration-short) ease;
  }

  .cart-notification__quantity-button:hover {
    background-color: rgba(var(--color-foreground), 0.12);
  }

  .cart-notification__quantity-input {
    width: 3.4rem;
    height: 3.2rem;
    text-align: center;
    border: 0;
    background: transparent;
    font-size: 1.5rem;
    color: rgb(var(--color-foreground));
    -moz-appearance: textfield;
  }

  .cart-notification__quantity-input::-webkit-outer-spin-button,
  .cart-notification__quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-notification-product.is-loading {
    opacity: 0.5;
    pointer-events: none;
  }
{% endstyle %}
