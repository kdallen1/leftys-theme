{{ 'section-main-about-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="about-page-section color-{{ section.settings.color_scheme }} gradient">
  <div class="about-page__content section-{{ section.id }}-padding">
    <div class="page-width">
      <div class="about-page__wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">

        <!-- Main Heading -->
        <h1 class="about-page__main-heading">About Lefty's</h1>

        <!-- Subheading -->
        <h2 class="about-page__subheading">FINE WESTERN WEAR FOR THE DISCERNING GENTLEMAN</h2>

        <!-- Brand Story -->
        <div class="about-page__brand-story">
          <p><span class="script-initial">We</span> are in the midst of a renaissance in western wear. Pearl snaps and cowboy boots, once confined to the cattle ranch, have become a minor staple in modern menswear. (Clearly somebody done left the gate open.)</p>

          <p>Yet as America once again dreams of the Wild West, popular brands just peddle a neutered take on country fashion, devoid of spirit and divorced from tradition. They've taken a colorful history and painted it corporate gray.</p>

          <p>At Lefty's, we draw from the past to design clothes for the present. We start with the best materials we can find, such as 180GSM 100% cotton. Then we build bold, tasteful pearl snap shirts that look as good as they feel.</p>
        </div>

        <!-- The Man Behind Lefty's Section -->
        <h3 class="about-page__section-heading">THE MAN BEHIND LEFTY'S</h3>
        <div class="about-page__founders-section">
          <img src="{{ 'kevin.JPG' | asset_url }}" alt="Kevin Allen" class="founders__group-photo">

          <div class="about-page__founders-text">
            <p class="about-page__founders-intro">Lefty's Western Wear was started in 2025 by Kevin Allen, a born-and-raised Texan with a passion for country music and authentic western wear.</p>

            <div class="about-page__founders-bios">
              <p>Kevin Allen is a scientist and a poet.</p>
              <p>He is also the 2nd best harmonica player in Austin, TX.</p>
            </div>
          </div>
        </div>

        <!-- Get In Touch Section -->
        <h3 class="about-page__section-heading">GET IN TOUCH</h3>
        <div class="about-page__contact">
          <p>Email us at <a href="mailto:kevin@shopleftys.com" class="contact-link">kevin@shopleftys.com</a></p>
          <p>Follow us on Instagram <a href="https://instagram.com/leftys_tx" target="_blank" class="contact-link">@leftys_tx</a></p>
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Main About Page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ]
}
{% endschema %}
